# 忽略实际数据文件（用户运行时生成）
data/channels/*
data/identities/*
data/relationships/*
!data/.gitkeep
!data/channels/.gitkeep
!data/identities/.gitkeep
!data/relationships/.gitkeep

# 忽略 Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 忽略 IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略操作系统文件
.DS_Store
Thumbs.db

# 忽略日志
*.log

# 忽略环境变量文件（包含敏感信息）
.env
.env.local
